{
  "manifest_version": 3,
  "name": "Ollama RAG Assistant",
  "version": "1.0",
  "description": "Chat con Ollama local + RAG sencillo con archivos de texto.",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Ollama RAG"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}